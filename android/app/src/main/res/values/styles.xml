<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- One horizontal "line" shared by the header and every prayer row, so the
         glyph / name / time columns line up vertically across all of them. -->
    <style name="WidgetLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="GlyphCol">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="NameCol">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:textColor">@color/label_dim</item>
        <item name="android:textSize">14sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TimeCol">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:text">--:--</item>
    </style>

    <style name="CityCol">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:textColor">@color/gold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.10</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Compact variants for the 2x2 size -->
    <style name="WidgetLineCompact" parent="WidgetLine">
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:paddingTop">1dp</item>
        <item name="android:paddingBottom">1dp</item>
    </style>

    <style name="NameColCompact" parent="NameCol">
        <item name="android:paddingStart">0dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TimeColCompact" parent="TimeCol">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CityColCompact" parent="CityCol">
        <item name="android:paddingStart">0dp</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
