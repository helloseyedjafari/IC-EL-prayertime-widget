<?xml version="1.0" encoding="utf-8"?>
<!-- Single responsive layout. Rows use layout_weight so they fill the widget's
     height (no dead margin when it grows), and PrayerWidgetProvider scales every
     font to the widget's actual size so text stays readable and never clips. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Header: moon in the glyph column, city in the name column -->
    <LinearLayout style="@style/WidgetLine">
        <TextView android:id="@+id/glyph_hdr" style="@style/GlyphCol" android:text="🌙" />
        <TextView android:id="@+id/city" style="@style/CityCol" android:text="—" />
        <TextView
            android:id="@+id/stale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•"
            android:textColor="@color/gold"
            android:alpha="0.4"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_dawn" style="@style/WidgetRow">
        <TextView android:id="@+id/glyph_dawn" style="@style/GlyphCol" android:text="☀" />
        <TextView android:id="@+id/name_dawn" style="@style/NameCol" android:text="Dawn" />
        <TextView android:id="@+id/dawn_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_sunrise" style="@style/WidgetRow">
        <TextView android:id="@+id/glyph_sunrise" style="@style/GlyphCol" android:text="◐" />
        <TextView android:id="@+id/name_sunrise" style="@style/NameCol" android:text="Sunrise" />
        <TextView android:id="@+id/sunrise_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_noon" style="@style/WidgetRow">
        <TextView android:id="@+id/glyph_noon" style="@style/GlyphCol" android:text="☉" />
        <TextView android:id="@+id/name_noon" style="@style/NameCol" android:text="Noon" />
        <TextView android:id="@+id/noon_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_maghrib" style="@style/WidgetRow">
        <TextView android:id="@+id/glyph_maghrib" style="@style/GlyphCol" android:text="☾" />
        <TextView android:id="@+id/name_maghrib" style="@style/NameCol" android:text="Maghrib" />
        <TextView android:id="@+id/maghrib_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_midnight" style="@style/WidgetRow">
        <TextView android:id="@+id/glyph_midnight" style="@style/GlyphCol" android:text="☾" />
        <TextView android:id="@+id/name_midnight" style="@style/NameCol" android:text="Midnight" />
        <TextView android:id="@+id/midnight_time" style="@style/TimeCol" />
    </LinearLayout>

    <TextView
        android:id="@+id/next_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="4dp"
        android:text=""
        android:textColor="@color/gold_dim"
        android:textSize="11sp"
        android:maxLines="1" />
</LinearLayout>
