<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Header: moon in the glyph column, city in the name column -->
    <LinearLayout style="@style/WidgetLine" android:paddingBottom="6dp">
        <TextView style="@style/GlyphCol" android:text="🌙" android:textSize="14sp" />
        <TextView android:id="@+id/city" style="@style/CityCol" android:text="—" />
        <TextView
            android:id="@+id/stale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•"
            android:textColor="@color/gold"
            android:alpha="0.4"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_dawn" style="@style/WidgetLine">
        <TextView style="@style/GlyphCol" android:text="☀" />
        <TextView style="@style/NameCol" android:text="Dawn" />
        <TextView android:id="@+id/dawn_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_sunrise" style="@style/WidgetLine">
        <TextView style="@style/GlyphCol" android:text="◐" />
        <TextView style="@style/NameCol" android:text="Sunrise" />
        <TextView android:id="@+id/sunrise_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_noon" style="@style/WidgetLine">
        <TextView style="@style/GlyphCol" android:text="☉" />
        <TextView style="@style/NameCol" android:text="Noon" />
        <TextView android:id="@+id/noon_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_maghrib" style="@style/WidgetLine">
        <TextView style="@style/GlyphCol" android:text="☾" />
        <TextView style="@style/NameCol" android:text="Maghrib" />
        <TextView android:id="@+id/maghrib_time" style="@style/TimeCol" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_midnight" style="@style/WidgetLine">
        <TextView style="@style/GlyphCol" android:text="☾" />
        <TextView style="@style/NameCol" android:text="Midnight" />
        <TextView android:id="@+id/midnight_time" style="@style/TimeCol" />
    </LinearLayout>

    <TextView
        android:id="@+id/next_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="6dp"
        android:text=""
        android:textColor="@color/gold_dim"
        android:textSize="11sp" />
</LinearLayout>
