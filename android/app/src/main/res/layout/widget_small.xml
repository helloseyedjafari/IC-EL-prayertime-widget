<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="7dp"
    android:paddingBottom="7dp">

    <LinearLayout style="@style/WidgetLineCompact" android:paddingBottom="3dp">
        <TextView android:id="@+id/city" style="@style/CityColCompact" android:text="—" />
        <TextView
            android:id="@+id/stale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•"
            android:textColor="@color/gold"
            android:alpha="0.4"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_dawn" style="@style/WidgetLineCompact">
        <TextView style="@style/NameColCompact" android:text="Dawn" />
        <TextView android:id="@+id/dawn_time" style="@style/TimeColCompact" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_sunrise" style="@style/WidgetLineCompact">
        <TextView style="@style/NameColCompact" android:text="Sunrise" />
        <TextView android:id="@+id/sunrise_time" style="@style/TimeColCompact" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_noon" style="@style/WidgetLineCompact">
        <TextView style="@style/NameColCompact" android:text="Noon" />
        <TextView android:id="@+id/noon_time" style="@style/TimeColCompact" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_maghrib" style="@style/WidgetLineCompact">
        <TextView style="@style/NameColCompact" android:text="Maghrib" />
        <TextView android:id="@+id/maghrib_time" style="@style/TimeColCompact" />
    </LinearLayout>

    <LinearLayout android:id="@+id/row_midnight" style="@style/WidgetLineCompact">
        <TextView style="@style/NameColCompact" android:text="Midnight" />
        <TextView android:id="@+id/midnight_time" style="@style/TimeColCompact" />
    </LinearLayout>

    <TextView
        android:id="@+id/next_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="2dp"
        android:text=""
        android:textColor="@color/gold_dim"
        android:textSize="9sp"
        android:maxLines="1" />
</LinearLayout>
